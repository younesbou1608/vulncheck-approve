# =========================================================
# VulnCheck & Approve v2 - configuration d'environnement
# Ports/identifiants VOLONTAIREMENT différents de la stack v1
# (5432/8082/8000/3001/9090/3000, user vulncheck) pour cohabiter
# sans conflit sur la même machine.
# =========================================================

# === Base de données PostgreSQL ===
POSTGRES_DB=vulncheck_v2
POSTGRES_USER=vc2_app
POSTGRES_PASSWORD=Vc2-Pg-9f4KzR
POSTGRES_PORT=55432

# === Clé API NVD (https://nvd.nist.gov/developers/request-an-api-key) ===
NVD_API_KEY=colle_ta_cle_ici

# === Ports des services (tous décalés vs v1) ===
AIRFLOW_PORT=8180
API_PORT=8100
FRONTEND_PORT=3101
PROMETHEUS_PORT=9190
GRAFANA_PORT=3200

# === API : matching sémantique (embeddings) ===
SEMANTIC_ENABLED=true

# === Scoring : filtre strict des CPE joker sans plage (correctif v2) ===
# true (défaut) : une CVE "toutes versions, sans borne" est ignorée quand
# une version précise est testée. false : ancien comportement.
STRICT_WILDCARD_FILTER=true

# === Explication IA (Claude) - optionnelle ===
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# === Grafana ===
GRAFANA_USER=vc2_admin
GRAFANA_PASSWORD=Vc2-Gf-7mQxT

# === Divers ===
LOG_LEVEL=INFO
