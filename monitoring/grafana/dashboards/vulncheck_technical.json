{
  "uid": "vulncheck-technical",
  "title": "VulnCheck - Supervision technique",
  "description": "Santé de l'API FastAPI (trafic, latence, erreurs), de PostgreSQL et suivi de la qualité du matching.",
  "tags": ["vulncheck", "infra"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "API - Requêtes par seconde (par route)",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "vulncheck-prometheus" },
      "targets": [
        { "expr": "sum by (handler) (rate(http_requests_total{job=\"vulncheck_api\"}[$__rate_interval]))", "legendFormat": "{{handler}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "API - Latence HTTP p95 (par route)",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "vulncheck-prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (handler, le) (rate(http_request_duration_seconds_bucket{job=\"vulncheck_api\"}[$__rate_interval])))", "legendFormat": "{{handler}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "API - Taux d'erreurs (4xx / 5xx)",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "vulncheck-prometheus" },
      "targets": [
        { "expr": "sum (rate(http_requests_total{job=\"vulncheck_api\", status=~\"4..\"}[$__rate_interval]))", "legendFormat": "4xx", "refId": "A" },
        { "expr": "sum (rate(http_requests_total{job=\"vulncheck_api\", status=~\"5..\"}[$__rate_interval]))", "legendFormat": "5xx", "refId": "B" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "5xx" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] },
          { "matcher": { "id": "byName", "options": "4xx" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }] }
        ]
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "PostgreSQL - Connexions actives",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "vulncheck-prometheus" },
      "targets": [
        { "expr": "sum by (state) (pg_stat_activity_count)", "legendFormat": "{{state}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "PostgreSQL - Transactions (commits / rollbacks)",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "vulncheck-prometheus" },
      "targets": [
        { "expr": "sum (rate(pg_stat_database_xact_commit{datname!~\"template.*\"}[$__rate_interval]))", "legendFormat": "commits/s", "refId": "A" },
        { "expr": "sum (rate(pg_stat_database_xact_rollback{datname!~\"template.*\"}[$__rate_interval]))", "legendFormat": "rollbacks/s", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Qualité du matching - part des méthodes utilisées (dérive)",
      "description": "Une montée du fuzzy/sémantique ou du 'none' signale une dérive : alias à enrichir ou embeddings à rafraîchir.",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "vulncheck-prometheus" },
      "targets": [
        { "expr": "sum by (match_method) (increase(vulncheck_validations_total[$__rate_interval]))", "legendFormat": "{{match_method}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "bars", "fillOpacity": 60, "stacking": { "mode": "normal" } } }, "overrides": [] }
    }
  ]
}
